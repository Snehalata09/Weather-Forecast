<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/mainScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@drawable/bg_gradient">

        <LinearLayout
            android:id="@+id/containerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:clipToPadding="false">

            <!-- Header Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/welcome_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weather Forecast"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>

                <ImageButton
                    android:id="@+id/btnLogout"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/ic_logout"
                    android:contentDescription="Logout"
                    android:background="@drawable/bg_glass_card"
                    android:padding="10dp"
                    android:layout_alignParentEnd="true"
                    app:tint="@color/white" />
            </RelativeLayout>

            <!-- Search Bar Section - Enhanced for Visibility (Request 1) -->
            <LinearLayout
                android:id="@+id/layoutSearchBar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_search_bar"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="10dp"
                android:elevation="4dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/search"
                    app:tint="#D0FFFFFF" />

                <EditText
                    android:id="@+id/etCitySearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@null"
                    android:hint="Search City..."
                    android:textColorHint="#99FFFFFF"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:maxLines="1"
                    android:inputType="textPersonName"
                    android:imeOptions="actionSearch" />

                <ImageButton
                    android:id="@+id/btnSearchAction"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/search"
                    app:tint="#FFFFFF"
                    android:contentDescription="Search"/>

            </LinearLayout>

            <!-- Current Weather Details Layout -->
            <LinearLayout
                android:id="@+id/layoutCurrentWeather"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="30dp">

                <TextView
                    android:id="@+id/tvCity1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvDate1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp"/>

                <ImageView
                    android:id="@+id/imgWeather"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginTop="20dp"
                    android:contentDescription="Weather Icon"/>

                <TextView
                    android:id="@+id/tvTemp1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textSize="72sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tvCondition1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Grid Details System - Improved for Request 2 -->
            <GridLayout
                android:id="@+id/layoutGridDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="true"
                android:alignmentMode="alignMargins">

                <!-- Humidity Card -->
                <LinearLayout
                    android:id="@+id/cardHumidity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_margin="6dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_humidity"
                        app:tint="@color/button_end"/>

                    <TextView
                        android:id="@+id/tvHumidity1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--%"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Humidity"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Wind Speed Card -->
                <LinearLayout
                    android:id="@+id/cardWind"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_margin="6dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_wind"
                        app:tint="@color/button_end"/>

                    <TextView
                        android:id="@+id/tvWind1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- m/s"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wind Speed"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Pressure Card -->
                <LinearLayout
                    android:id="@+id/cardPressure"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_margin="6dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_pressure"
                        app:tint="@color/button_end"/>

                    <TextView
                        android:id="@+id/tvPressure1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- hPa"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pressure"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Feels Like Card -->
                <LinearLayout
                    android:id="@+id/cardFeelsLike"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_margin="6dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_temp"
                        app:tint="@color/button_end"/>

                    <TextView
                        android:id="@+id/tvFeelsLike1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--°C"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Feels Like"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </GridLayout>

            <!-- 5 Day Forecast Section -->
            <TextView
                android:id="@+id/tvForecastTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5-Day Forecast"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="30dp"
                android:layout_marginStart="6dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerForecast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:scrollbars="none"
                android:paddingBottom="40dp"
                android:clipToPadding="false"/>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>